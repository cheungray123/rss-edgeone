{
  "version": 2,
  "name": "rss-edgeone",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "default": {
      "runtime": "nodejs20",
      "entry": "cloud-functions/[[default]].js",
      "routes": [
        {
          "pattern": "/*",
          "target": "function",
          "function": "default"
        }
      ]
    }
  }
}